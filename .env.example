PORT=8080
ADMIN_KEY=change-me
MAX_REPLAY_MESSAGES=20
MAX_QUERY_CHARS=12000
CONTEXT_RESET_THRESHOLD=0
MAX_CONCURRENT_PER_ACCOUNT=999999
THINK_MODE=separate
SESSION_TTL_DAYS=7

# 会话隔离模式：
# - auto: 自动基于 IP + User-Agent 隔离会话（推荐，防止不同客户端记忆混淆）
# - manual: 只有客户端提供 x-session-id 时才隔离（默认所有请求共享会话）
# - per-request: 每个请求都是新会话（禁用记忆）
SESSION_ISOLATION=auto
